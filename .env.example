# ──────────────────────────────────────────────
# Flight Intelligence — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env    (Linux/Mac)
#   copy .env.example .env  (Windows)

# ── OpenSky Network API ──────────────────────
# Register free: https://opensky-network.org
#
# Option A: OAuth2 (recommended, required since March 2026)
#   1. Log in at https://opensky-network.org
#   2. Go to Account -> API Clients
#   3. Create a new API client
#   4. Copy client_id and client_secret here
OPENSKY_CLIENT_ID=your_client_id_here
OPENSKY_CLIENT_SECRET=your_client_secret_here
#
# Option B: Legacy basic auth (deprecated since March 2026)
# Only works for accounts created before March 2025
OPENSKY_USERNAME=your_username_here
OPENSKY_PASSWORD=your_password_here

# ── Google Cloud Platform ────────────────────
# 1. Create project: https://console.cloud.google.com
# 2. Enable BigQuery API
# 3. Create Service Account → download JSON key
# 4. Place key in ./credentials/gcp-credentials.json
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=flight_intelligence

# ── Local Mode (DuckDB) ─────────────────────
# Set to "true" to run without BigQuery (for development/testing)
USE_LOCAL_DB=true
LOCAL_DB_PATH=./data/flight_intelligence.duckdb
